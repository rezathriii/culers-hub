# ── Required ─────────────────────────────────────────────────────────────────

# Your Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwXyz

# The channel/group to post to.
# For a public channel use:  @your_channel_username
# For a private channel use the numeric chat ID (negative number), e.g. -1001234567890
TELEGRAM_CHAT_ID=@your_channel_username

# ── Optional ─────────────────────────────────────────────────────────────────

# How often to poll the feeds (minutes). Default: 30
CHECK_INTERVAL_MINUTES=30

# Only send articles published within this many hours. 0 = no limit. Default: 1
MAX_ARTICLE_AGE_HOURS=1

# Seconds to wait between sending each article to Telegram. Default: 60
SEND_INTERVAL_SECONDS=60

# Aggressive fuzzy dedup threshold (0.0-1.0). Lower = stricter duplicate filtering.
# Recommended aggressive value: 0.35
DEDUP_SIMILARITY_THRESHOLD=0.35

# ── LLM Summarizer ───────────────────────────────────────────────────────────
# Set LLM_ENABLED=false to fall back to raw RSS excerpts
LLM_ENABLED=true
LLM_BASE_URL=http://localhost:9000
LLM_TIMEOUT=30

# Translate title + summary to Persian using local LLM only
TRANSLATE_TO_PERSIAN=true
LLM_TRANSLATION_TIMEOUT=30
